# US Visa Bot Configuration
# Copy this file to .env and fill in your actual values

# Your credentials for https://ais.usvisa-info.com/
EMAIL=your.email@example.com
PASSWORD=your_password_here

# Country code from the AIS URL. Spain uses https://ais.usvisa-info.com/en-es
COUNTRY_CODE=es

# Schedule ID - found in your own URL when trying to reschedule manually
# URL format: https://ais.usvisa-info.com/en-es/niv/schedule/{SCHEDULE_ID}/continue_actions
SCHEDULE_ID=12345678

# Madrid facility ID
FACILITY_ID=7

# Refresh delay in seconds between checks (optional, defaults to 3)
REFRESH_DELAY=3
