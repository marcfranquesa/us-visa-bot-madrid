# US Visa Bot Configuration
# Copy this file to .env and fill in your actual values

# Your credentials for https://ais.usvisa-info.com/
EMAIL=your.email@example.com
PASSWORD=your_password_here

# Base AIS URL through /niv. Use the locale from your reschedule URL.
# Example for Madrid/Spain: https://ais.usvisa-info.com/es-es/niv
BASE_URI=https://ais.usvisa-info.com/es-es/niv

# Schedule ID - found in the URL when trying to reschedule manually
# URL format: https://ais.usvisa-info.com/{locale}/niv/schedule/{SCHEDULE_ID}/continue_actions
SCHEDULE_ID=12345678

# Facility ID - found in network calls when selecting a new date or inspecting the selector
# Examples: Paris is 44
# URL format: https://ais.usvisa-info.com/{locale}/niv/schedule/{SCHEDULE_ID}/appointment/address/{FACILITY_ID}
FACILITY_ID=44

# Refresh delay in seconds between checks (optional, defaults to 3)
REFRESH_DELAY=3
